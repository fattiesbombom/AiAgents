## Database
# PostgreSQL connection string for the input (ops + RAG) database.
INPUT_DB_URL=postgresql://security:security@postgres-input:5432/security_input
# PostgreSQL connection string for the output (dashboard) database.
OUTPUT_DB_URL=postgresql://security:security@postgres-output:5432/security_output

## Supabase Auth (cloud)
# Supabase project URL, e.g. https://xxxx.supabase.co
SUPABASE_URL=
# Supabase anon key (public) used for server-side token verification via /auth/v1/user.
SUPABASE_ANON_KEY=
# Supabase service role key (server-side admin access).
SUPABASE_SERVICE_ROLE_KEY=

## AI Models (all local via Ollama — no external API calls)
# Ollama server base URL.
OLLAMA_BASE_URL=http://ollama:11434
# Chat/reasoning model for text agent nodes.
LLM_MODEL=qwen3.5
# Vision model for multimodal analysis.
VISION_MODEL=qwen3.5
# Embedding model used for SOP retrieval.
EMBEDDING_MODEL=nomic-embed-text
# Embedding vector dimensions (nomic-embed-text outputs 768).
EMBEDDING_DIMENSIONS=768

## YOLO
# Path or name of the Ultralytics YOLO model weights.
YOLO_MODEL_PATH=yolov8n.pt
# Minimum confidence for a detection to be kept.
YOLO_CONFIDENCE_THRESHOLD=0.5
# Comma-separated labels considered threats.
YOLO_THREAT_LABELS=person,fire,smoke,weapon

## Perception
# Directory where snapshots are stored.
SNAPSHOT_STORAGE_PATH=./data/snapshots
# Frame sampling interval (seconds).
FRAME_SAMPLE_INTERVAL_SECONDS=2
# Cooldown window (seconds) to avoid duplicate triggers.
TRIGGER_COOLDOWN_SECONDS=30

## Input DB perception poller (discrete events → POST /trigger; see backend/perception/input_db_watcher.py)
# Master switch. When true, run: python -m backend.perception.start_input_db_watcher
INPUT_DB_WATCHER_ENABLED=false
# Seconds between poll cycles.
INPUT_DB_POLL_INTERVAL_SECONDS=5
# Comma-separated tables: alarm_events, mop_reports, access_logs, motion_events, c2_alerts
INPUT_DB_TABLES=alarm_events,mop_reports,access_logs
# Only alarm_events rows whose severity (case-insensitive) is in this list; empty = allow all
INPUT_DB_ALARM_SEVERITIES=
# Skip alarm rows already acknowledged in DB
INPUT_DB_ALARM_SKIP_ACKNOWLEDGED=true
# access_logs: trigger when attempt_result matches any of these (case-insensitive)
INPUT_DB_ACCESS_TRIGGER_RESULTS=denied,failed,tailgating,rejected
# motion_events (when listed in INPUT_DB_TABLES): minimum confidence to fire
INPUT_DB_MOTION_MIN_CONFIDENCE=0
# JSON file storing per-table (timestamp, id) cursors; empty = memory-only
INPUT_DB_CURSOR_FILE=./data/input_db_watcher_cursors.json
# Max rows fetched per table per poll
INPUT_DB_POLL_BATCH_SIZE=50

## FastAPI
# API host binding.
API_HOST=0.0.0.0
# API port.
API_PORT=8000
# Comma-separated CORS allowed origins.
ALLOWED_ORIGINS=http://localhost:5173

## MCP
# Local FastMCP streamable-http servers listen on these ports at path / (root).
# Port for the input-db MCP server.
MCP_INPUT_DB_PORT=8001
# Port for the output-db MCP server.
MCP_OUTPUT_DB_PORT=8002
# Port for the auth-db MCP server.
MCP_AUTH_DB_PORT=8003

## Officer heartbeat watches (HeartbeatWatcher + start_perception_watchers)
HEARTBEAT_POLL_INTERVAL_SECONDS=5
HEARTBEAT_NO_SIGNAL_THRESHOLD=3
HEARTBEAT_FLAT_LINE_THRESHOLD=10
HEARTBEAT_ELEVATED_BPM=140
HEARTBEAT_ELEVATED_DURATION_SECONDS=60
HEARTBEAT_TRIGGER_COOLDOWN_SECONDS=120
# Comma-separated officer_id|poll_url (Supabase user UUID or badge-linked id)
HEARTBEAT_WATCHERS=
# Base URL for POST /trigger (FastAPI)
TRIGGER_API_BASE_URL=http://127.0.0.1:8000

## Demo mode — Android IP Webcam
# IP shown in IP Webcam app on your phone.
PHONE_IP=192.168.1.x
# IP Webcam port, default 8080.
PHONE_PORT=8080
# Where demo frames are saved.
DEMO_SNAPSHOT_PATH=./data/demo_snapshots
# Key to manually fire a trigger.
DEMO_MANUAL_TRIGGER_KEY=space
